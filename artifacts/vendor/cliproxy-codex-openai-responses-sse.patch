+func (e *CodexExecutor) forwardCodexOpenAIResponsesStream(ctx context.Context, r io.Reader, out chan<- cliproxyexecutor.StreamChunk, reporter *helps.UsageReporter, replayScope codexReasoningReplayScope, identityState codexIdentityConfuseState, requestBody []byte) error {
+	reader := bufio.NewReader(r)
+	outputItemsByIndex := make(map[int64][]byte)
+	var outputItemsFallback [][]byte
+	var frame codexOpenAIResponsesSSEFrame
+
+	sendPayload := func(payload []byte) bool {
+		select {
+		case out <- cliproxyexecutor.StreamChunk{Payload: payload}:
+			return true
+		case <-ctx.Done():
+			return false
+		}
+	}
+
+	emit := func() error {
+		defer frame.reset()
+		if !frame.hasData() {
+			return nil
+		}
+		payload := bytes.TrimSpace(frame.payload())
+		if len(payload) == 0 {
+			return nil
+		}
+		if bytes.Equal(payload, []byte("[DONE]")) {
+			if !sendPayload(formatCodexOpenAIResponsesSSEFrame("", payload)) {
+				return ctx.Err()
+			}
+			return nil
+		}
+
+		eventType := gjson.GetBytes(payload, "type").String()
+		if frame.event == "" {
+			frame.event = eventType
+		}
+		if streamErr, terminalBody, ok := codexTerminalStreamErr(payload); ok {
+			if errClearReplay := clearCodexReasoningReplayOnInvalidSignature(ctx, replayScope, streamErr.StatusCode(), terminalBody); errClearReplay != nil {
+				return errClearReplay
+			}
+			return streamErr
+		}
+
+		switch eventType {
+		case "response.output_item.done":
+			collectCodexOutputItemDone(payload, outputItemsByIndex, &outputItemsFallback)
+		case "response.completed":
+			if detail, ok := helps.ParseCodexUsage(payload); ok {
+				reporter.Publish(ctx, detail)
+			}
+			publishCodexImageToolUsage(ctx, reporter, requestBody, payload)
+			payload = patchCodexCompletedOutput(payload, outputItemsByIndex, outputItemsFallback)
+			cacheCodexReasoningReplayFromCompleted(replayScope, payload)
+		}
+
+		payload = applyCodexIdentityExposeResponsePayload(payload, identityState)
+		if !sendPayload(formatCodexOpenAIResponsesSSEFrame(frame.event, payload)) {
+			return ctx.Err()
+		}
+		return nil
+	}
+
+	for {
+		line, readErr := reader.ReadBytes('\n')
+		if len(line) > 0 {
+			line = bytes.TrimRight(line, "\r\n")
+			line = applyCodexIdentityConfuseResponsePayload(line, identityState)
+			helps.AppendAPIResponseChunk(ctx, e.cfg, line)
+			if len(bytes.TrimSpace(line)) == 0 {
+				if errEmit := emit(); errEmit != nil {
+					return errEmit
+				}
+			} else {
+				frame.addLine(line)
+			}
+		}
+		if readErr == io.EOF {
+			return emit()
+		}
+		if readErr != nil {
+			return fmt.Errorf("codex stream read: %w", readErr)
+		}
+	}
+}
