@@ -41,6 +41,58 @@ const (
 
 var dataTag = []byte("data:")
 
+type codexOpenAIResponsesSSEFrame struct {
+	event string
+	data  [][]byte
+}
+
+func (f *codexOpenAIResponsesSSEFrame) reset() {
+	f.event = ""
+	f.data = f.data[:0]
+}
+
+func (f *codexOpenAIResponsesSSEFrame) addLine(line []byte) {
+	trimmed := bytes.TrimSpace(line)
+	if len(trimmed) == 0 {
+		return
+	}
+	if bytes.HasPrefix(trimmed, []byte("event:")) {
+		f.event = strings.TrimSpace(string(trimmed[len("event:"):]))
+		return
+	}
+	if bytes.HasPrefix(trimmed, dataTag) {
+		data := bytes.TrimSpace(trimmed[len(dataTag):])
+		f.data = append(f.data, append([]byte(nil), data...))
+	}
+}
+
+func (f *codexOpenAIResponsesSSEFrame) hasData() bool {
+	return len(f.data) > 0
+}
+
+func (f *codexOpenAIResponsesSSEFrame) payload() []byte {
+	if len(f.data) == 0 {
+		return nil
+	}
+	return bytes.Join(f.data, []byte("\n"))
+}
+
+func formatCodexOpenAIResponsesSSEFrame(eventName string, payload []byte) []byte {
+	var out bytes.Buffer
+	if eventName = strings.TrimSpace(eventName); eventName != "" {
+		out.WriteString("event: ")
+		out.WriteString(eventName)
+		out.WriteByte('\n')
+	}
+	for _, line := range bytes.Split(payload, []byte("\n")) {
+		out.WriteString("data: ")
+		out.Write(line)
+		out.WriteByte('\n')
+	}
+	out.WriteByte('\n')
+	return out.Bytes()
+}
