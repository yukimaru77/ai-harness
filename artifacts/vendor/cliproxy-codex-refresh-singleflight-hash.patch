+func TestCodexRefreshSingleflightKey_UsesSHA256Hex(t *testing.T) {
+	const token = "sentinel-token-a"
+
+	got := codexRefreshSingleflightKey(token)
+	sum := sha256.Sum256([]byte(token))
+	want := hex.EncodeToString(sum[:])
+
+	if got != want {
+		t.Fatal("singleflight key is not the expected SHA-256 hex digest")
+	}
+	if got == token {
+		t.Fatal("singleflight key must not be the raw token")
+	}
+	if len(got) != sha256.Size*2 {
+		t.Fatalf("singleflight key length = %d, want %d", len(got), sha256.Size*2)
+	}
+	if got == codexRefreshSingleflightKey("sentinel-token-b") {
+		t.Fatal("different tokens unexpectedly produced the same test key")
+	}
+}
