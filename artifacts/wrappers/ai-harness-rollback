#!/usr/bin/env bash
set -euo pipefail

DRY_RUN=0
case "${1:-}" in
  --dry-run) DRY_RUN=1 ;;
  "" ) ;;
  * )
    echo "usage: ai-harness-rollback [--dry-run]" >&2
    exit 64
    ;;
esac

LABEL="com.nonaka.ai-harness.cliproxy"
SOURCE_LINE='[ -f "$HOME/.config/ai-harness/shell.sh" ] && . "$HOME/.config/ai-harness/shell.sh"'
TS="$(date +%Y%m%d-%H%M%S)"
QUAR="$HOME/.local/share/ai-harness/quarantine/$TS"
REPORT_DIR="$HOME/.local/share/ai-harness/reports"
REPORT="$REPORT_DIR/rollback-$TS.md"

log() {
  printf '%s\n' "$*"
}

run() {
  if [ "$DRY_RUN" -eq 1 ]; then
    printf '[dry-run]'
    for arg in "$@"; do printf ' %q' "$arg"; done
    printf '\n'
  else
    "$@"
  fi
}

record() {
  if [ "$DRY_RUN" -eq 1 ]; then
    return 0
  fi
  printf '%s\n' "$*" >> "$REPORT"
}

move_if_exists() {
  local src="$1"
  local dst="$2"
  if [ ! -e "$src" ]; then
    record "- skip missing: \`$src\`"
    return 0
  fi
  run mkdir -p "$(dirname "$dst")"
  run mv "$src" "$dst"
  record "- moved: \`$src\` -> \`$dst\`"
}

remove_source_line() {
  local rc="$1"
  [ -f "$rc" ] || return 0
  if ! grep -Fqx "$SOURCE_LINE" "$rc"; then
    record "- no harness source line in: \`$rc\`"
    return 0
  fi
  if [ "$DRY_RUN" -eq 1 ]; then
    log "[dry-run] remove harness source line from $rc"
    return 0
  fi
  local tmp="$rc.ai-harness-rollback.$$"
  grep -vF "$SOURCE_LINE" "$rc" > "$tmp" || true
  mv "$tmp" "$rc"
  record "- removed harness source line from: \`$rc\`"
}

verify_real_path() {
  local cmd="$1"
  local filtered_path
  filtered_path="$(printf '%s' "$PATH" | awk -v RS=: -v ORS=: '$0 != ENVIRON["HOME"]"/.local/share/ai-harness/bin" {print}' | sed 's/:$//')"
  PATH="$filtered_path" command -v "$cmd" 2>/dev/null || true
}

if [ "$DRY_RUN" -eq 0 ]; then
  mkdir -p "$REPORT_DIR" "$QUAR"
  chmod 700 "$REPORT_DIR" "$QUAR"
  : > "$REPORT"
  chmod 600 "$REPORT"
fi

log "AI Harness rollback"
record "# AI Harness Rollback Report"
record ""
record "Date: $(date)"
record ""
record "Quarantine: \`$QUAR\`"
record ""

if [ "$DRY_RUN" -eq 1 ]; then
  run launchctl bootout "gui/$(id -u)/$LABEL"
else
  launchctl bootout "gui/$(id -u)/$LABEL" >/dev/null 2>&1 || true
fi
record "- attempted LaunchAgent unload: \`$LABEL\`"

for rc in "$HOME/.zshrc" "$HOME/.zprofile" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
  remove_source_line "$rc"
done

move_if_exists "$HOME/.local/share/ai-harness/bin" "$QUAR/bin"
move_if_exists "$HOME/Library/LaunchAgents/$LABEL.plist" "$QUAR/$LABEL.plist"
move_if_exists "$HOME/.local/libexec/ai-harness/cli-proxy-api" "$QUAR/libexec/cli-proxy-api"
move_if_exists "$HOME/.local/libexec/ai-harness/cli-proxy-api-start" "$QUAR/libexec/cli-proxy-api-start"
move_if_exists "$HOME/.config/ai-harness/cliproxy" "$QUAR/config/cliproxy"
move_if_exists "$HOME/.local/share/ai-harness/cliproxy/auth" "$QUAR/share/cliproxy-auth"
move_if_exists "$HOME/.config/ai-harness/claude" "$QUAR/config/claude"
move_if_exists "$HOME/.config/ai-harness/claude-codex" "$QUAR/config/claude-codex"
move_if_exists "$HOME/.config/ai-harness/claude-glm" "$QUAR/config/claude-glm"
move_if_exists "$HOME/.config/ai-harness/opencode" "$QUAR/config/opencode"
move_if_exists "$HOME/.config/ai-harness/state" "$QUAR/config/state"
move_if_exists "$HOME/.codex/oauth-gpt.config.toml" "$QUAR/codex/oauth-gpt.config.toml"
move_if_exists "$HOME/.codex/glm.config.toml" "$QUAR/codex/glm.config.toml"

record ""
record "Credentials intentionally retained unless already moved as auth-store quarantine:"
record "- \`$HOME/.config/ai-harness/secrets\`"
record ""
record "Real command resolution without harness PATH:"
for cmd in claude codex opencode; do
  resolved="$(verify_real_path "$cmd")"
  record "- $cmd: ${resolved:-not found}"
done

if [ "$DRY_RUN" -eq 1 ]; then
  log "Dry run complete. No files were moved."
else
  log "AI Harness rolled back. Quarantine: $QUAR"
  log "Rollback report: $REPORT"
fi
