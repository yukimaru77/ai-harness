#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.config/ai-harness/paths.env"
. "$HOME/.local/share/ai-harness/lib/obs.sh"
OBS_WRAPPER_VERSION=2
obs_init codex-fusion "$@"

unset CLIPROXY_API_KEY OPENAI_API_KEY OPENAI_BASE_URL

obs_event route_resolved provider=native_codex_oauth model=gpt-5.5 real_bin="$REAL_CODEX"

obs_run "$REAL_CODEX" \
  --dangerously-bypass-approvals-and-sandbox \
  -c 'model="gpt-5.5"' \
  -c 'model_reasoning_effort="xhigh"' \
  -c 'plan_mode_reasoning_effort="xhigh"' \
  -c 'model_context_window=400000' \
  -c 'model_auto_compact_token_limit=250000' \
  "$@"
