#!/usr/bin/env bash
# codex-moe — Codex CLI through the item-level fusion proxy (fusion-api
# instance "codex-moe", Responses protocol, :8401). Candidates are GPT/GLM
# only (no Claude models on the Codex harness). Starts in passthrough; switch
# with the /moe custom prompt or: ai-harness-fusion on codex-moe
set -euo pipefail
. "$HOME/.config/ai-harness/paths.env"
. "$HOME/.local/share/ai-harness/lib/obs.sh"
OBS_WRAPPER_VERSION=1
obs_init codex-moe "$@"

CLIENT_KEY_FILE="$AI_HARNESS_HOME/secrets/cliproxy-client.key"
[ -r "$CLIENT_KEY_FILE" ] || {
  obs_event fatal reason=missing_client_key file="$CLIENT_KEY_FILE"
  echo "missing CLIProxyAPI client key" >&2
  exit 70
}
CLIENT_KEY="$(cat "$CLIENT_KEY_FILE")"
obs_redact_add "$CLIENT_KEY"

FUSION_URL="http://127.0.0.1:8401"
if ! obs_curl_probe fusion_codex_moe "$FUSION_URL/health"; then
  obs_event fatal reason=fusion_api_unreachable url="$FUSION_URL"
  echo "fusion-api (codex-moe instance) is not running. Run: ai-harness-fusion diag codex-moe" >&2
  exit 69
fi

export CODEX_HOME="$HOME/.agent-fusion/codex"
export CLIPROXY_API_KEY="$CLIENT_KEY"
unset OPENAI_API_KEY OPENAI_BASE_URL CODEX_ACCESS_TOKEN

obs_event route_resolved \
  provider=fusion_api \
  base_url="$FUSION_URL/v1" \
  model=fusion-v1 \
  fusion_mode="$(cat "$HOME/.agent-fusion/fusion-mode-codex-moe" 2>/dev/null || echo passthrough)" \
  real_bin="$REAL_CODEX"

obs_run "$REAL_CODEX" \
  --dangerously-bypass-approvals-and-sandbox \
  -c "model_providers.fusion={ name = 'Fusion MoE', base_url = '$FUSION_URL/v1', env_key = 'CLIPROXY_API_KEY', wire_api = 'responses', requires_openai_auth = false }" \
  -c 'model_provider="fusion"' \
  -c 'model="fusion-v1"' \
  -c "model_providers.fusion.http_headers.x-ai-harness-trace=\"$AI_HARNESS_TRACE_ID\"" \
  -c 'model_reasoning_effort="high"' \
  -c 'model_context_window=400000' \
  -c 'model_auto_compact_token_limit=250000' \
  -c 'features.enable_request_compression=false' \
  "$@"
