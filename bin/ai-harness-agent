#!/usr/bin/env bash
# ai-harness-agent — manage which skills and MCP servers the harness routes
# see (cc-switch style: central store -> symlink selection).
#
#   Central skill store : ~/.agents/skills           (shared with cc-switch)
#   Selection           : ~/.agent-fusion/skills     (symlinks only; default empty)
#   MCP selection       : ~/.agent-fusion/mcp.json   (default: no servers)
#
# Only what is linked/listed here reaches claude-fusion, claude-codex,
# claude-glm, codex-fusion, and codex-glm. The user's normal ~/.claude and
# ~/.codex are untouched.
#
# Usage:
#   ai-harness-agent list                 show skills + MCP: store/candidates vs selection
#   ai-harness-agent select               interactive: ask about every skill and MCP candidate
#   ai-harness-agent add <skill>...       symlink skill(s) from the store
#   ai-harness-agent remove <skill>...    remove from selection
#   ai-harness-agent mcp-add <name>...    copy MCP server def from ~/.claude.json
#   ai-harness-agent mcp-remove <name>... remove MCP server from selection
#   ai-harness-agent mcp                  open the MCP selection file in an editor
#   ai-harness-agent sync                 re-wire agent homes (idempotent)
set -euo pipefail

STORE="$HOME/.agents/skills"
AF="$HOME/.agent-fusion"
SEL="$AF/skills"

usage() { sed -n '2,20p' "$0"; exit 64; }

sync() {
  mkdir -p "$SEL" "$AF/claude" "$AF/codex" "$AF/xdg/opencode"
  [ -f "$AF/mcp.json" ] || printf '{\n  "mcpServers": {}\n}\n' > "$AF/mcp.json"
  ln -sfn "$SEL" "$AF/claude/skills"
  [ -e "$HOME/.claude/CLAUDE.md" ] && ln -sfn "$HOME/.claude/CLAUDE.md" "$AF/claude/CLAUDE.md"
  # Share the native Anthropic login with the user's ~/.claude (per-config-dir
  # credential file) and mirror the account fields so /login is not required.
  [ -e "$HOME/.claude/.credentials.json" ] && ln -sfn "$HOME/.claude/.credentials.json" "$AF/claude/.credentials.json"
  [ -f "$AF/claude/.claude.json" ] || printf '{"hasCompletedOnboarding": true}\n' > "$AF/claude/.claude.json"
  if [ -f "$HOME/.claude.json" ] && command -v python3 >/dev/null 2>&1; then
    python3 - "$HOME/.claude.json" "$AF/claude/.claude.json" <<'PY'
import json, sys
src = json.load(open(sys.argv[1]))
try:
    dst = json.load(open(sys.argv[2]))
except Exception:
    dst = {}
for k in ("oauthAccount", "userID", "hasCompletedOnboarding"):
    if k in src:
        dst[k] = src[k]
dst.setdefault("hasCompletedOnboarding", True)
json.dump(dst, open(sys.argv[2], "w"), indent=2)
PY
  fi
  ln -sfn "$HOME/.codex/auth.json" "$AF/codex/auth.json"
  ln -sfn "$SEL" "$AF/codex/skills"
  ln -sfn "$SEL" "$AF/xdg/opencode/skills"
  # Drop dangling selection links (skill removed from the store)
  local link
  for link in "$SEL"/*; do
    [ -L "$link" ] && [ ! -e "$link" ] && rm -f "$link" && echo "removed dangling: $(basename "$link")"
  done
  echo "sync ok"
}

# MCP candidates come from the user's normal Claude Code config (~/.claude.json
# mcpServers). mcp-add copies a candidate's full definition into the selection.
mcp_candidates() {
  python3 -c "import json,os;d=json.load(open(os.path.expanduser('~/.claude.json')));print('\n'.join(d.get('mcpServers',{})))" 2>/dev/null || true
}

mcp_selected() {
  python3 -c "import json;d=json.load(open('$AF/mcp.json'));print('\n'.join(d.get('mcpServers',{})))" 2>/dev/null || true
}

mcp_add() {
  local name="$1"
  python3 - "$name" "$AF/mcp.json" <<'PY'
import json, os, sys
name, sel_path = sys.argv[1], sys.argv[2]
src = json.load(open(os.path.expanduser("~/.claude.json"))).get("mcpServers", {})
if name not in src:
    raise SystemExit(f"not a candidate in ~/.claude.json mcpServers: {name}")
sel = json.load(open(sel_path))
sel.setdefault("mcpServers", {})[name] = src[name]
json.dump(sel, open(sel_path, "w"), indent=2)
print(f"mcp selected: {name}")
PY
}

mcp_remove() {
  local name="$1"
  python3 - "$name" "$AF/mcp.json" <<'PY'
import json, sys
name, sel_path = sys.argv[1], sys.argv[2]
sel = json.load(open(sel_path))
sel.get("mcpServers", {}).pop(name, None)
json.dump(sel, open(sel_path, "w"), indent=2)
print(f"mcp deselected: {name}")
PY
}

do_list() {
  echo "Skills — store: $STORE, selection: $SEL"
  local s name mark
  for s in "$STORE"/*/; do
    name="$(basename "$s")"
    if [ -e "$SEL/$name" ]; then mark="[selected]"; else mark="[ ]"; fi
    printf '  %-10s %s\n' "$mark" "$name"
  done
  echo "MCP servers — candidates from ~/.claude.json, selection: $AF/mcp.json"
  local cand
  for cand in $(mcp_candidates); do
    if mcp_selected | grep -qx "$cand"; then
      printf '  %-10s %s\n' "[selected]" "$cand"
    else
      printf '  %-10s %s\n' "[ ]" "$cand"
    fi
  done
  [ -n "$(mcp_candidates)" ] || echo "  (no candidates)"
}

case "${1:-}" in
  list)
    do_list
    ;;
  select)
    # Interactive walk-through: ask about EVERY store skill and EVERY MCP
    # candidate. Also the flow an AI agent should mirror in chat (see
    # docs/AGENT_SETUP.md).
    [ -t 0 ] || { echo "select needs a TTY; use list/add/remove/mcp-add non-interactively" >&2; exit 64; }
    for s in "$STORE"/*/; do
      name="$(basename "$s")"
      cur="n"; [ -e "$SEL/$name" ] && cur="y"
      printf 'skill %-30s include? [y/n, current=%s]: ' "$name" "$cur"
      IFS= read -r ans
      [ -n "$ans" ] || ans="$cur"
      case "$ans" in
        y|Y) ln -sfn "$STORE/$name" "$SEL/$name" ;;
        *) rm -f "$SEL/$name" ;;
      esac
    done
    for cand in $(mcp_candidates); do
      cur="n"; mcp_selected | grep -qx "$cand" && cur="y"
      printf 'mcp   %-30s include? [y/n, current=%s]: ' "$cand" "$cur"
      IFS= read -r ans
      [ -n "$ans" ] || ans="$cur"
      case "$ans" in
        y|Y) mcp_add "$cand" >/dev/null ;;
        *) mcp_remove "$cand" >/dev/null ;;
      esac
    done
    echo "--- result:"
    do_list
    ;;
  mcp-add)
    shift; [ "$#" -ge 1 ] || usage
    for name in "$@"; do mcp_add "$name"; done
    ;;
  mcp-remove)
    shift; [ "$#" -ge 1 ] || usage
    for name in "$@"; do mcp_remove "$name"; done
    ;;
  add)
    shift; [ "$#" -ge 1 ] || usage
    for name in "$@"; do
      src="$STORE/$name"
      [ -d "$src" ] || { echo "not in store: $name" >&2; exit 66; }
      ln -sfn "$src" "$SEL/$name"
      echo "selected: $name"
    done
    ;;
  remove)
    shift; [ "$#" -ge 1 ] || usage
    for name in "$@"; do
      rm -f "$SEL/$name"
      echo "deselected: $name"
    done
    ;;
  mcp)
    echo "Edit $AF/mcp.json (mcpServers map, same format as .claude.json / --mcp-config)."
    "${EDITOR:-open -t}" "$AF/mcp.json"
    ;;
  sync)
    sync
    ;;
  *)
    usage
    ;;
esac
