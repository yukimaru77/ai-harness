#!/usr/bin/env bash
# claude-moe — Claude Code through the item-level fusion proxy (fusion-api).
# Starts in passthrough mode (single model); use the /moe slash command (or
# `ai-harness-fusion on`) to switch every subsequent item to fan-out+synthesis
# across the configured candidate models.
set -euo pipefail
. "$HOME/.config/ai-harness/paths.env"
. "$HOME/.local/share/ai-harness/lib/obs.sh"
OBS_WRAPPER_VERSION=1
obs_init claude-moe "$@"

CLIENT_KEY_FILE="$AI_HARNESS_HOME/secrets/cliproxy-client.key"
[ -r "$CLIENT_KEY_FILE" ] || {
  obs_event fatal reason=missing_client_key file="$CLIENT_KEY_FILE"
  echo "missing CLIProxyAPI client key" >&2
  exit 70
}
CLIENT_KEY="$(cat "$CLIENT_KEY_FILE")"
obs_redact_add "$CLIENT_KEY"

FUSION_URL="http://127.0.0.1:8400"
if ! obs_curl_probe fusion_api "$FUSION_URL/health"; then
  obs_event fatal reason=fusion_api_unreachable url="$FUSION_URL"
  echo "fusion-api is not running. launchctl kickstart -k gui/$(id -u)/com.nonaka.ai-harness.fusion" >&2
  exit 69
fi

export CLAUDE_CONFIG_DIR="$HOME/.agent-fusion/claude"
export ANTHROPIC_BASE_URL="$FUSION_URL"
# Deliberately NO ANTHROPIC_AUTH_TOKEN: Claude Code keeps its native
# claude.ai OAuth login (preserving claude.ai connectors); fusion-api
# accepts the local request regardless (accept_any_local_auth) and swaps
# in its own upstream key.
export ANTHROPIC_MODEL="fusion-v1"
export ANTHROPIC_SMALL_FAST_MODEL="fusion-bg"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="fusion-bg"
export ANTHROPIC_CUSTOM_HEADERS="x-ai-harness-trace: $AI_HARNESS_TRACE_ID"
unset ANTHROPIC_API_KEY OPENAI_API_KEY OPENAI_BASE_URL

obs_event route_resolved \
  base_url="$FUSION_URL" \
  model=fusion-v1 \
  fusion_mode="$(cat "$HOME/.agent-fusion/fusion-mode-claude-moe" 2>/dev/null || echo passthrough)" \
  real_bin="$REAL_CLAUDE"

obs_run "$REAL_CLAUDE" \
  --settings "$AI_HARNESS_HOME/claude/moe-settings.json" \
  --model fusion-v1 \
  --strict-mcp-config --mcp-config "$HOME/.agent-fusion/mcp.json" \
  --dangerously-skip-permissions \
  "$@"
